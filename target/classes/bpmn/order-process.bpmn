  <bpmn:process id="order-process" name="Order Process" isExecutable="true">
    <bpmn:serviceTask id="approveOrderTask" name="Approve Order">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="approve-order" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_18w3dnm</bpmn:incoming>
      <bpmn:outgoing>flow3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="createOrderTask" name="Create Order">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="create-order" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow1</bpmn:incoming>
      <bpmn:outgoing>flow2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end" name="End">
      <bpmn:incoming>flow3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_18w3dnm" sourceRef="Activity_1eqmbl4" targetRef="approveOrderTask" />
    <bpmn:sequenceFlow id="flow1" sourceRef="start" targetRef="createOrderTask" />
    <bpmn:sequenceFlow id="flow2" sourceRef="createOrderTask" targetRef="Activity_1eqmbl4" />
    <bpmn:sequenceFlow id="flow3" sourceRef="approveOrderTask" targetRef="end" />
    <bpmn:userTask id="Activity_1eqmbl4" name="Manager">
      <bpmn:incoming>flow2</bpmn:incoming>
      <bpmn:outgoing>Flow_18w3dnm</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="start" name="Start">
      <bpmn:outgoing>flow1</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
